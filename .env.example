# Auth (shared avec cloe-api — même valeur)
JWT_SECRET=REPLACE_WITH_HEX64_SAME_AS_CLOE_API
SERVICE_SECRET=REPLACE_WITH_HEX32

# Cloe-api callback (endpoint /internal/apply-patch)
CLOE_API_URL=http://cloe-api:8700
CLOE_API_KEY=REPLACE_WITH_SERVICE_SECRET

# LLM via cloe-proxy (toujours bill_to_operator pour cloe-care)
CLOE_PROXY_URL=http://cloe-proxy:8000
OPERATOR_OPENROUTER_KEY=sk-or-v1-OPERATOR_KEY

# Notifications email
RESEND_API_KEY=re_xxx
EMAIL_FROM=cloe@hellocloe.fr
EMAIL_REPLY_TO=care@hellocloe.fr

# GitHub (issues + global fix proposals)
GITHUB_TOKEN=ghp_xxx
GITHUB_REPO_OWNER=paoli01

# Storage limits + chemins SQLite/attachments
MAX_UPLOAD_SIZE_MB=10
MAX_ATTACHMENTS_PER_TICKET=5
CARE_DB_PATH=/opt/cloe-care/data/care.db
CARE_ATTACHMENTS_PATH=/opt/cloe-care/data/attachments

# Service-key partagé avec cloe-api (= CARE_SERVICE_KEY côté cloe-api).
# Permet à cloe-api d'ouvrir des tickets internes côté care.
CARE_SERVICE_KEY=REPLACE_WITH_HEX64

# ── Read-only paths (lecture seule pour care, géré par cloe-api) ─────
# Racine clients (registry, sessions par tenant).
CLOE_CLIENTS_RO=/opt/cloe/clients
# Fichier registry.json (mapping client_id → display + plan + etc.).
REGISTRY_PATH=/opt/cloe-api/registry.json
# DB SQLite du proxy LLM (lecture pour stats / coût).
CLOE_PROXY_DB_PATH=/opt/cloe/proxy/cloe_proxy.db

# Docker logs via socket-proxy LOGS-only (cf. DEPLOYMENT.md isolation).
DOCKER_HOST=tcp://127.0.0.1:2375

# Cookies (true en production HTTPS)
COOKIE_SECURE=true

# Admins (séparés par virgule, comparés en lowercase)
ADMIN_EMAILS=

# Safe mode initial : bloque file_replace en début de production
CARE_SAFE_MODE=true

# Logs
LOG_LEVEL=INFO
