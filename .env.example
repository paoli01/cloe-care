# Auth (shared avec cloe-api — même valeur)
JWT_SECRET=REPLACE_WITH_HEX64_SAME_AS_CLOE_API
SERVICE_SECRET=REPLACE_WITH_HEX32

# Cloe-api callback (endpoint /internal/apply-patch)
CLOE_API_URL=http://cloe-api:8700
CLOE_API_KEY=REPLACE_WITH_SERVICE_SECRET

# LLM via cloe-proxy (toujours bill_to_operator pour cloe-care)
CLOE_PROXY_URL=http://cloe-proxy:8000
OPERATOR_OPENROUTER_KEY=sk-or-v1-OPERATOR_KEY

# Notifications email
RESEND_API_KEY=re_xxx
EMAIL_FROM=cloe@hellocloe.fr
EMAIL_REPLY_TO=care@hellocloe.fr

# GitHub (issues + global fix proposals)
GITHUB_TOKEN=ghp_xxx
GITHUB_REPO_OWNER=paoli01

# Storage limits
MAX_UPLOAD_SIZE_MB=10
MAX_ATTACHMENTS_PER_TICKET=5

# Cookies (true en production HTTPS)
COOKIE_SECURE=true

# Admins (séparés par virgule, comparés en lowercase)
ADMIN_EMAILS=

# Safe mode initial : bloque file_replace en début de production
CARE_SAFE_MODE=true

# Logs
LOG_LEVEL=INFO
